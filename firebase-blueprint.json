{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a registered user on the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Incident": {
      "title": "Incident",
      "description": "A detected threat or scanned content.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["TEXT", "LINK", "IMAGE"] },
        "content": { "type": "string" },
        "riskLevel": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "category": { "type": "string" },
        "explanation": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "riskLevel", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile information."
    },
    "users/{userId}/incidents/{incidentId}": {
      "schema": "Incident",
      "description": "Collection of threats detected for a specific user."
    }
  }
}
